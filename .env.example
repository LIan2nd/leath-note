# ============================================
# ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values.
# For Vercel deployments, set these in the Vercel Dashboard per environment.
#
# Environments:
#   - Development: local dev (npm run dev)
#   - Preview: Vercel preview deployments (PR/branch deploys)
#   - Production: Vercel production (main branch)

# ─── Database (Supabase) ───────────────────
# https://www.prisma.io/docs/guides/database/supabase
#
# DATABASE_URL = connection pooler (Transaction mode, port 6543)
# DIRECT_URL  = direct connection (port 5432) — needed for migrations
#
# For local dev, you can use a local PostgreSQL:
#   DATABASE_URL="postgresql://postgres:root@localhost:5432/leath-note"
#
# For Supabase:
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Authentication ────────────────────────
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=""

# Google OAuth (optional — configure in Google Cloud Console)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── AI (optional) ─────────────────────────
# Only needed if you want server-side Ollama defaults.
# Users configure their own AI provider in the app UI.
# Not needed for Vercel deployments.
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# ─── Build ─────────────────────────────────
# Set to "1" to skip env validation during build (useful for Docker/CI)
# SKIP_ENV_VALIDATION="1"
